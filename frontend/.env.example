# Database (Required) - Use Neon or any PostgreSQL provider
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# NextAuth (Required) - Update URL for production
NEXTAUTH_URL="https://your-domain.vercel.app"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Apify (Required for social features) - Get from https://apify.com
APIFY_TOKEN="your-apify-token"

# Google OAuth (Optional) - Get from Google Cloud Console
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Razorpay (Optional) - Get from https://razorpay.com
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
